APP_NAME="Personal Reminder Assistant"
APP_VERSION="0.2.0"
DEBUG=false
API_V1_PREFIX="/api/v1"

# SQLite database path (default: reminders.db in project root)
DATABASE_URL="sqlite:///./reminders.db"

# How often to check for due reminders (seconds)
SCHEDULER_INTERVAL_SECONDS=30

# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""

# Channel chat ID (usually starts with -100). Add the bot as a channel admin first.
TELEGRAM_CHAT_ID=""
